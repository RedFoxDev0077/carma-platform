# ============ CARMA environment ============
# Copy to .env and fill in. Never commit the real .env.

ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-long-random-string

# ---- Database ----
POSTGRES_USER=carma
POSTGRES_PASSWORD=carma
POSTGRES_DB=carma
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ---- Redis / Celery ----
REDIS_URL=redis://localhost:6379/0

# ---- WhatsApp (Meta Cloud API) ----
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WABA_ID=
WHATSAPP_TOKEN=
WHATSAPP_VERIFY_TOKEN=carma-verify-me
WHATSAPP_APP_SECRET=
WHATSAPP_SESSION_MINUTES=30
AI_MESSAGE_LIMIT=15

# ---- Payments ----
# provider: stripe | culqi
PAYMENT_PROVIDER=stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
REPORT_PRICE_SOLES=29.90
CURRENCY=PEN

# ---- RPA / cost control ----
CAPTCHA_API_KEY=
CAPTCHA_PROVIDER=2captcha
RPA_PAID_COST_SOLES=6.10          # cost of the SUNARP paid lookup per report
RPA_TIMEOUT_SECONDS=45
RPA_MAX_CONCURRENCY=7

# ---- AI (LLM advisor) ----
ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-5
LLM_MAX_TOKENS=1024

# ---- Support ----
SUPPORT_EMAIL=soporte@carma.pe
PUBLIC_BASE_URL=https://api.carma.pe
